# Deadline Room environment template. Copy to .env and fill in your own values.
#   cp .env.example .env
#
# NONE of these are needed to run the deterministic core or the test suite
# (py -m pytest tests/ runs with no keys and no network). Keys are only needed
# to run the live floor against Band and the model providers.

# Band platform. The USER key (band_u_...) provisions; each agent has its own
# AGENT key (band_a_...) created in the Band web UI under Connect Remote Agent.
BAND_BASE_URL=https://app.band.ai/api/v1
BAND_USER_KEY=band_u_your_user_key_here

# The Warden and the five drafter agents (one agent key + agent id each).
BAND_API_KEY=band_a_warden_key_here
BAND_AGENT_ID=warden_agent_uuid_here
BAND_API_KEY_2=band_a_nis2_drafter_key_here
BAND_AGENT_ID_2=nis2_drafter_agent_uuid_here
BAND_API_KEY_3=band_a_triage_key_here
BAND_AGENT_ID_3=triage_agent_uuid_here
BAND_API_KEY_4=band_a_sec_drafter_key_here
BAND_AGENT_ID_4=sec_drafter_agent_uuid_here
BAND_API_KEY_5=band_a_dora_drafter_key_here
BAND_AGENT_ID_5=dora_drafter_agent_uuid_here
BAND_API_KEY_6=band_a_uk_drafter_key_here
BAND_AGENT_ID_6=uk_drafter_agent_uuid_here

# Named role aliases the roster also accepts (point these at the same agents above).
BAND_API_KEY_TRIAGE=band_a_triage_key_here
BAND_AGENT_ID_TRIAGE=triage_agent_uuid_here
BAND_API_KEY_SEC=band_a_sec_drafter_key_here
BAND_AGENT_ID_SEC=sec_drafter_agent_uuid_here
BAND_API_KEY_DORA=band_a_dora_drafter_key_here
BAND_AGENT_ID_DORA=dora_drafter_agent_uuid_here
BAND_API_KEY_UK=band_a_uk_drafter_key_here
BAND_AGENT_ID_UK=uk_drafter_agent_uuid_here

# Model providers. Featherless powers the dev path (flat rate, open models).
# AI/ML API powers the prod split (--provider prod) for the parallel drafters.
FEATHERLESS_API_KEY=your_featherless_key_here
AIML_API_KEY=your_aimlapi_key_here
